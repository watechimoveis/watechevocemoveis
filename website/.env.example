# Build-time — URL do painel admin (login corretor redireciona para cá)
VITE_ADMIN_URL=http://localhost:5173

# WhatsApp da imobiliária (empty state / contato geral) — só dígitos, ex.: 5511999999999
# VITE_CONTACT_WHATSAPP=5511999999999

# Build-time — URL da API (em dev, vazio = proxy Vite em /api)
# VITE_API_URL=http://localhost:8000

# Production (Render preenche automaticamente via render.yaml):
# VITE_ADMIN_URL=https://watech-admin.onrender.com
# VITE_API_URL=https://watech-api.onrender.com
