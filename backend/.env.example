# Local development — copy to .env and adjust
DATABASE_URL=postgresql://watech:watech@localhost:5432/watechimoveis

APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

ADMIN_EMAIL=admin@watech.com
ADMIN_PASSWORD=admin123

JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=480

UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5

# Supabase Storage (produção — fotos persistentes)
# SUPABASE_URL=https://SEU_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
# STORAGE_BUCKET=property-images

# --- Production (Render + Supabase) ---
# Copie em: Supabase → Project Settings → Database → Connection string → URI
# Use "Session pooler" (porta 5432) ou "Direct connection" para migrations.
# A região no host (aws-0, aws-1…) deve bater com o projeto — senão: tenant/user not found
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[SENHA]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require
# APP_ENV=production
# CORS_ORIGINS=https://watech-site.onrender.com,https://watech-admin.onrender.com
